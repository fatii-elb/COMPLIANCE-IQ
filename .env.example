# ---------------------------------------------------------------------------
# ComplianceIQ AI Service — environment template.
# Copy to `.env` and fill in. `.env` is gitignored; NEVER commit real secrets.
# Every value here is read via pydantic-settings (see
# src/complianceiq/infrastructure/config/settings.py). Twelve-factor: all
# configuration comes from the environment, never from source.
# ---------------------------------------------------------------------------

# --- Core service identity ---
CIQ_APP_NAME=complianceiq-ai
CIQ_ENVIRONMENT=local            # local | dev | staging | production
CIQ_DEBUG=false
CIQ_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
CIQ_LOG_JSON=true                # false = human-readable console logs for local dev

# --- HTTP server ---
CIQ_HOST=0.0.0.0
CIQ_PORT=8000
CIQ_REQUEST_MAX_BYTES=1048576    # 1 MiB request-size limit

# --- Security / auth (JWT is issued by the Core Service; we only verify) ---
# The Core Service signs tenant JWTs. In production this is an asymmetric key
# or a JWKS URL. Left empty here; auth wiring lands in Phase 6.
CIQ_JWT_AUDIENCE=complianceiq
CIQ_JWT_ISSUER=complianceiq-core
CIQ_JWT_PUBLIC_KEY=

# --- Database (PostgreSQL + pgvector) — wired in Phase 6 ---
CIQ_DATABASE_URL=postgresql+asyncpg://complianceiq:complianceiq@postgres:5432/complianceiq

# --- LLM providers — wired in Phase 2. Leave blank to use the fake provider. ---
CIQ_ANTHROPIC_API_KEY=
CIQ_LLM_PRIMARY_PROVIDER=fake    # fake | anthropic

# --- Core Service client — wired in Phase 6. Points at the stub locally. ---
CIQ_CORE_API_BASE_URL=http://core-stub:9000
